        :type nums: List[int]
        :type k: int
        :rtype: int
        """
        import math
        left=0
        prod=1
        arr=[]
        sumi=0
        for right in range(len(nums)):
            prod*=nums[right]
            while (prod>=k) and left<len(nums) and right>=left:
                prod/=nums[left]
                left+=1
                print(right-left+1, nums[right], right, left, prod)
                #if prod<k:
            sumi+=((right-left+1))
        print(sumi)
        return sumi
